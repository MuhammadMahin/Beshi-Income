                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/privacy_policy"
                android:textColor="@color/colorAccentDemo"
                android:textSize="17sp"
                app:drawableEndCompat="@drawable/ic_baseline_gpp_maybe_24" />


            <TextView
                android:id="@+id/settings_txt_7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/app_rules32"
                android:textColor="@color/colorAccentDemo"
                android:textSize="16sp"
                app:drawableEndCompat="@drawable/ic_baseline_security_24" />

            <TextView
                android:id="@+id/settings_txt_8"
