                android:layout_marginTop="15dp"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/update_new_version"
                android:textColor="@color/colorAccentDemo"
                android:textSize="16sp"
                app:drawableEndCompat="@drawable/ic_baseline_wifi_protected_setup_24" />

            <!--Gone text 7-->
            <LinearLayout
                android:id="@+id/gone_text_7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/app_name"
                    android:textColor="@color/sexy_blue"
                    android:textSize="23sp" />

                <TextView
                    android:layout_width="155dp"
                    android:layout_height="4dp"
                    android:background="@drawable/button_shape"
                    android:backgroundTint="@color/green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/app_rules30"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/version"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/update_"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_rules31_"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/app_rules33_"
                    android:textColor="@color/black"
