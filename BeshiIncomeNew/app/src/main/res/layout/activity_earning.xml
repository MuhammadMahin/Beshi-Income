<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Home">

    <TextView
        android:id="@+id/earning_main_heading"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/button_shape"
        android:backgroundTint="@color/sexy_blue"
        android:fontFamily="@font/poppins_bold"
        android:paddingTop="5dp"
        android:text="স্পিন গেম খেলুন"
        android:textAlignment="center"
        android:textColor="@color/white_smoke"
        android:textSize="25sp" />


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/e_earning_lottie"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_centerInParent="true"
        android:layout_marginBottom="12dp"
        android:visibility="visible"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/spin" />



    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/earning_bottom_navigator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:visibility="visible"
        app:itemIconTint="@color/bottom_color_nav"
        app:itemRippleColor="@null"
        app:itemTextColor="@color/bottom_color_nav"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>