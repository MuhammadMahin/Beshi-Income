<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Home">

    <include
        android:id="@+id/header_homes"
        layout="@layout/header_home" />

    <TextView
        android:id="@+id/main_heading2"
        android:layout_below="@+id/header_homes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_centerHorizontal="true"
        android:text="@string/play_to_win_10_taka"
        android:textSize="25sp"
        android:includeFontPadding="false"
        android:layout_marginHorizontal="10dp"
        android:textColor="@color/green"
        android:fontFamily="@font/poppins_bold"
        />

    <TextView
        android:id="@+id/main_heading21"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/main_heading2"
        android:layout_centerInParent="true"
        android:fontFamily="@font/poppins_bold"
        android:text="@string/step_2_of_3"
        android:textColor="@color/colorAccentDemo"
        android:textSize="25sp"
        android:visibility="visible" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/step_one_two_lottie"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_below="@+id/main_heading21"
        android:layout_centerInParent="true"
        android:layout_marginTop="10dp"
        android:visibility="visible"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/mahin_timer" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/twoLottie"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_centerInParent="true"
        android:visibility="visible"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/cutebaby" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/final_lottie2"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_centerInParent="true"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/coins"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/step_two_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="15dp"
        android:text="@string/againPly"
        android:textColor="@color/white"
        android:textSize="25sp"
        android:textStyle="bold"
        android:transitionName="button_tran"
        android:background="@drawable/line_shape"
        android:backgroundTint="@color/gold"
        android:layout_gravity="center"
        android:layout_below="@+id/twoLottie"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        />

</RelativeLayout>
